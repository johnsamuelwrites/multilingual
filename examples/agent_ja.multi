# 多言語AIエージェント — 日本語
# agent_en.multi と agent_fr.multi と同じエージェントロジック。
# Multilingualが、エージェントコードがどの人間言語でも
# 慣用的である唯一のAIプラットフォームであることを証明する。
#
# 実演する機能:
#   @ツール, @エージェント, @クラウド, 考える, 尋ねる, 並列 [ ... ], 起動,
#   メモリ, トレース, コスト, 説明, 使う 効果

@ツール(説明="現在の情報をウェブで検索する")
関数 ウェブ検索(クエリ: str) -> str 使う ネット:
    パス

@クラウド
@エージェント(モデル=@claude-sonnet)
関数 調査エージェント(質問: str) -> str 使う ai, ネット:
    # 回答キャッシュ用の永続メモリ
    変数 キャッシュ = メモリ("回答", scope="persistent")
    もし 質問 in キャッシュ:
        返す キャッシュ[質問]

    # まず考える：質問を並列サブクエリに分解する
    変数 計画 = 考える @claude-sonnet:
        この調査質問を、並列処理可能な2つの独立したサブクエリに分解する。
        質問: 質問

    # 並列を使って両方のサブクエリを同時実行する
    変数 結果群 = 並列 [
        コスト(尋ねる @claude-sonnet: 計画.結論 + "\n事実に集中する。"),
        トレース(尋ねる @claude-sonnet: 計画.結論 + "\n文脈に集中する。",
                "文脈-トレース")
    ]

    # 並列結果を統合して最終回答を生成する
    変数 コスト付き回答, 文脈 = 結果群[0], 結果群[1]
    変数 回答, コスト情報 = コスト付き回答

    # モデルに回答を説明させる
    変数 最終回答, 説明文 = 説明(回答)

    キャッシュ[質問] = 最終回答
    返す 最終回答

関数 メイン():
    変数 結果 = 調査エージェント("東京の人口は何人ですか？")
    表示(結果)
